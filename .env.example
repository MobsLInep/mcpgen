# Copy to .env and fill in. Never commit your real .env.

# Anthropic API key used by the generation engine (Phase 1+). The web/API never
# expose this to the browser; generation falls back to deterministic synthesis
# when it is unset.
ANTHROPIC_API_KEY=

# --- apps/api (Phase 5) ------------------------------------------------------
# Port the API service listens on (default 3001).
# PORT=3001
# Comma-separated allowed CORS origins, or "*" (default "*").
# MCPGEN_CORS_ORIGIN=http://localhost:3000
# Set to 1 to force the deterministic fake runner (used by tests/demo).
# MCPGEN_FAKE=0

# --- apps/web (Phase 5) ------------------------------------------------------
# Base URL of the API the browser talks to (default http://localhost:3001).
# NEXT_PUBLIC_API_URL=http://localhost:3001
