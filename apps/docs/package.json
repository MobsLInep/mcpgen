{
  "name": "@mcpgen/docs",
  "version": "0.0.0",
  "private": true,
  "description": "mcpgen documentation site (Nextra 4, Next.js 15 App Router).",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "search:index": "pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo public/_pagefind *.tsbuildinfo"
  },
  "dependencies": {
    "next": "^15.1.2",
    "nextra": "^4.0.0",
    "nextra-theme-docs": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "pagefind": "^1.3.0",
    "typescript": "^6.0.3"
  }
}
