{
  "name": "@mcpgen/api",
  "version": "0.0.0",
  "private": true,
  "description": "Backend service the mcpgen web UI calls: parse, generate-as-a-job, stream progress, and download.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@mcpgen/core": "workspace:*",
    "jszip": "^3.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
