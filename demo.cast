[16.017745, "o", "#!/usr/bin/env node\r\n/**\r\n * swagger_petstore-mcp — an MCP server generated by mcpgen.\r\n *\r\n * Exposes the upstream API's operations as MCP tools. Supports two transports,\r\n * selected by MCPGEN_TRANSPORT (or --transport at generation time):\r\n *   - \"stdio\": local use by an MCP client over stdin/stdout.\r\n *   - \"http\":  remote use over Streamable HTTP (POST /mcp).\r\n *\r\n * Generated by mcpgen — regenerate from the source spec rather than editing.\r\n */\r\nimport { McpServer } from \"@modelcontextprotocol/sdk/server/mcp.js\";\r\n"]
