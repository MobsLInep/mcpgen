/**
 * Runtime configuration, read from the environment.
 *
 * Generated by mcpgen. Credentials are NEVER hardcoded — they are read from the
 * environment variables documented in `.env.example` and injected into outbound
 * requests by `http.ts`. Review `SECURITY.md` before deploying.
 */

/** How a single credential is carried to the upstream API. */
export interface AuthScheme {
  readonly kind: "apiKey" | "bearer" | "basic" | "none";
  /** For apiKey schemes: where the value is placed. */
  readonly in?: "header" | "query";
  /** For apiKey schemes: the header/query parameter name. */
  readonly name?: string;
  /** Environment variable holding the secret. */
  readonly envVar: string;
}

/** OAuth 2.1 resource-server discovery metadata (RFC 9728). */
export interface OAuthConfig {
  /** Canonical URL of this resource server (the deployed /mcp origin). */
  readonly resource: string;
  /** Authorization server clients should use to obtain tokens. */
  readonly authorizationServer: string;
  /** Scopes advertised in the protected-resource metadata. */
  readonly scopes: string[];
}

export interface Config {
  /** Base URL of the upstream API. */
  readonly baseUrl: string;
  /** Selected MCP transport. */
  readonly transport: "stdio" | "http";
  /** Port for the Streamable HTTP transport. */
  readonly port: number;
  /** Credential schemes to apply to outbound requests. */
  readonly auth: AuthScheme[];
  /**
   * Host allow-list for DNS-rebinding protection on the http transport. Empty
   * disables the check (fine for local dev; set it before exposing publicly).
   */
  readonly allowedHosts: string[];
  /** CORS `Access-Control-Allow-Origin` value for the http transport. */
  readonly corsOrigin: string;
  /** OAuth 2.1 discovery metadata (used when the source requires OAuth). */
  readonly oauth: OAuthConfig;
}

/** Split a comma/space separated env value into a trimmed, non-empty list. */
function envList(value: string | undefined): string[] {
  return (value ?? "")
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);
}

/** Auth schemes derived from the source spec at generation time. */
const AUTH_SCHEMES: AuthScheme[] = {{AUTH_SCHEMES}};

function envTransport(): "stdio" | "http" {
  const t = (process.env.MCPGEN_TRANSPORT ?? "{{DEFAULT_TRANSPORT}}").toLowerCase();
  return t === "http" ? "http" : "stdio";
}

/** Load configuration from the environment. */
export function loadConfig(): Config {
  const baseUrl =
    process.env.MCPGEN_API_BASE_URL ?? "{{API_BASE_URL}}";
  if (!baseUrl) {
    throw new Error(
      "No upstream base URL configured. Set MCPGEN_API_BASE_URL.",
    );
  }
  const port = Number.parseInt(process.env.MCPGEN_HTTP_PORT ?? "3000", 10);
  const resolvedPort = Number.isFinite(port) ? port : 3000;
  return {
    baseUrl: baseUrl.replace(/\/+$/, ""),
    transport: envTransport(),
    port: resolvedPort,
    auth: AUTH_SCHEMES,
    allowedHosts: envList(process.env.MCPGEN_ALLOWED_HOSTS),
    corsOrigin: process.env.MCPGEN_CORS_ORIGIN ?? "*",
    oauth: {
      resource:
        process.env.MCPGEN_OAUTH_RESOURCE ??
        `http://localhost:${resolvedPort}/mcp`,
      authorizationServer: process.env.MCPGEN_OAUTH_AUTH_SERVER ?? "",
      scopes: envList(process.env.MCPGEN_OAUTH_SCOPES),
    },
  };
}
