# Generated by mcpgen — Fly.io deployment for {{PACKAGE_NAME}}.
#
# First time:  fly launch --copy-config --no-deploy   # pick an app name + region
# Then:        fly deploy
# Secrets:     fly secrets set MCPGEN_API_BASE_URL=https://api.example.com \
#                              MCPGEN_BEARER_TOKEN=...        # never commit these
#
# `app` is a placeholder — `fly launch` rewrites it to your chosen name.
app = "{{PACKAGE_NAME}}"
primary_region = "iad"

[build]
  dockerfile = "Dockerfile"

[env]
  MCPGEN_TRANSPORT = "http"
  MCPGEN_HTTP_PORT = "3000"
  # Lock the public host(s) once you know your domain so DNS-rebinding
  # protection is enforced in production:
  # MCPGEN_ALLOWED_HOSTS = "{{PACKAGE_NAME}}.fly.dev"

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

  [[http_service.checks]]
    grace_period = "10s"
    interval = "30s"
    method = "GET"
    timeout = "5s"
    path = "/healthz"
