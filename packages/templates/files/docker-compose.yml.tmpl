# Generated by mcpgen — run {{PACKAGE_NAME}} over Streamable HTTP locally.
#
#   docker compose up --build
#
# The server then speaks MCP at http://localhost:3000/mcp and reports health at
# http://localhost:3000/healthz. Put upstream credentials in a sibling `.env`
# file (see `.env.example`) — it is loaded automatically and never baked into
# the image.
services:
  {{PACKAGE_NAME}}:
    build: .
    image: {{PACKAGE_NAME}}
    ports:
      - "3000:3000"
    environment:
      MCPGEN_TRANSPORT: http
      MCPGEN_HTTP_PORT: "3000"
    env_file:
      - path: .env
        required: false
    restart: unless-stopped
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - "fetch('http://localhost:3000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
