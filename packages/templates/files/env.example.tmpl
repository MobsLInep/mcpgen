# {{SERVER_NAME}} — environment configuration
# Generated by mcpgen. Copy to `.env` and fill in real values. NEVER commit secrets.

# Base URL of the upstream API.
MCPGEN_API_BASE_URL={{API_BASE_URL}}

# Transport: "stdio" (local) or "http" (Streamable HTTP).
MCPGEN_TRANSPORT={{DEFAULT_TRANSPORT}}

# Port for the http transport.
MCPGEN_HTTP_PORT=3000

# --- Remote hardening (only relevant for the http transport) ---
# Comma-separated Host allow-list. When set, the server enables DNS-rebinding
# protection and rejects requests whose Host header is not listed. Leave empty
# for local dev; set to your public domain(s) before exposing the server.
MCPGEN_ALLOWED_HOSTS=
# CORS origin for browser-based MCP clients. "*" is fine for local dev; lock it
# to your client's origin in production.
MCPGEN_CORS_ORIGIN=*
# OAuth 2.1 resource-server discovery (only used when auth is OAuth). These feed
# the /.well-known/oauth-protected-resource document MCP clients read.
MCPGEN_OAUTH_RESOURCE=
MCPGEN_OAUTH_AUTH_SERVER=
MCPGEN_OAUTH_SCOPES=

# --- Credentials (scoped to the upstream API; read at runtime, never hardcoded) ---
{{ENV_VARS}}
