{
  "name": "@mcpgen/core",
  "version": "0.1.0",
  "description": "mcpgen generation engine (pure library).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MobsLInep/mcpgen.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@mcpgen/templates": "workspace:*",
    "@readme/openapi-parser": "^6.1.3",
    "graphql": "^17.0.1",
    "ts-morph": "^28.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
